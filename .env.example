# ─────────────────────────────────────────────────────────────
# .env.example — Arokkiyam local development environment
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.
# ─────────────────────────────────────────────────────────────

# ── Encryption ────────────────────────────────────────────────
# Generate: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=REPLACE_WITH_32_BYTE_BASE64_KEY

# ── RSA Key Pair (IAM Service) ────────────────────────────────
# Generate:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the full PEM content (including headers) below.
RSA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nREPLACE_WITH_REAL_KEY\n-----END RSA PRIVATE KEY-----
RSA_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_REAL_KEY\n-----END PUBLIC KEY-----

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=local_root_password
MYSQL_DATABASE=arokkiyam
MYSQL_USER=arokkiyam_app
MYSQL_PASSWORD=local_app_password

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=local_redis_password

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── AWS (local dev uses Localstack) ──────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566

# ── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ── Service ports ─────────────────────────────────────────────
IAM_SERVICE_PORT=8081
AUDIT_SERVICE_PORT=8082
NOTIFICATION_SERVICE_PORT=8083

# ── SonarQube (local analysis) ────────────────────────────────
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=REPLACE_WITH_LOCAL_SONAR_TOKEN
SONAR_PROJECT_KEY=arokkiyam
SONAR_ORGANIZATION=arokkiyam
