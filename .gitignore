.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks

# ─── Docker ───────────────────────────────────────────────────
.docker/

# ─── Testcontainers ───────────────────────────────────────────
.testcontainers.properties

# ─── JaCoCo ───────────────────────────────────────────────────
*.exec

# ─── SonarQube ────────────────────────────────────────────────
.scannerwork/

