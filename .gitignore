*.class
*.jar
*.war
*.ear
*.nar

# ─── Logs ─────────────────────────────────────────────────────
*.log
logs/
spring.log

# ─── IDE ──────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
.vscode/
.settings/
.classpath
.project
.factorypath
*.launch
*.prefs

# ─── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Environment / Secrets ────────────────────────────────────
